---
import { FaGithub, FaExternalLinkAlt } from "react-icons/fa";

const projects = [
  {
    title: "POS System",
    description:
      "Sistema de punto de venta completo con gestión de inventario, ventas y reportes en tiempo real.",
    image: "/pos.webp",
    stack: ["Laravel", "React", "PostgreSQL", "Inertia", "Tailwind"],
    repo: "https://github.com/andfelipeme/pos",
    deploy: "https://posvhaj.duckdns.org/login",
    private: true,
  },
  {
    title: "Mapi Ant",
    description:
      "Controlador de gastos personales con dashboard de estadísticas, categorías y seguimiento mensual.",
    image: "/mapi-ant.webp",
    stack: ["Next.js", "React", "Tailwind"],
    repo: "https://github.com/andfelipeme/mapi-ant",
    deploy: "https://mapi-ant.duckdns.org/",
    private: false,
  },
];
---

<section class="py-20">

  <!-- Título sección -->
  <div class="flex flex-col gap-2 mb-12 text-center md:text-left">
    <p class="text-sm text-muted uppercase tracking-widest">Portafolio</p>
    <h2 class="text-4xl md:text-5xl font-bold">
      Mis <span class="text-accent">Proyectos</span>
    </h2>
  </div>

  <!-- Grid de cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {
      projects.map((project) => (
        <div class="flex flex-col rounded-2xl border border-white/10 overflow-hidden bg-bg-card hover:border-accent/30 transition-all duration-300 hover:-translate-y-1">

          <!-- Imagen -->
          <div class="relative overflow-hidden h-52">
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
            />
            <!-- Overlay sutil -->
            <div class="absolute inset-0 bg-linear-to-t from-bg-card/80 to-transparent" />
          </div>

          <!-- Contenido -->
          <div class="flex flex-col gap-4 p-6 flex-1">

            <!-- Título -->
            <h3 class="text-xl font-bold text-text">{project.title}</h3>

            <!-- Descripción -->
            <p class="text-muted text-sm leading-relaxed flex-1">
              {project.description}
            </p>

            <!-- Stack badges -->
            <div class="flex gap-2 flex-wrap">
              {project.stack.map((tech) => (
                <span class="text-xs px-3 py-1 rounded-full border border-accent/30 text-accent bg-accent/5">
                  {tech}
                </span>
              ))}
            </div>

            <!-- Links -->
            <div class="flex gap-4 pt-2">
              {!project.private && (
                <a
                  href={project.repo}
                  target="_blank"
                  class="flex items-center gap-2 text-sm text-muted hover:text-white transition-colors duration-200"
                >
                  <FaGithub className="text-lg" />
                  Repositorio
                </a>
              )}
              
              <a
                href={project.deploy}
                target="_blank"
                class="flex items-center gap-2 text-sm text-muted hover:text-accent transition-colors duration-200"
              >
                <FaExternalLinkAlt className="text-sm" />
                Ver deploy
              </a>
            </div>
          </div>    
        </div>
      ))
    }
  </div>
</section>