---
import { FaGithub } from "react-icons/fa";
import MobileMenu from "./MobileMenu.tsx";

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
];
---

<header
  class="text-white py-5 fixed z-50 top-5 left-1/2 -translate-x-1/2 w-[90%] max-w-4xl"
>
  <div
    class="relative flex justify-between items-center px-7 py-4 rounded-2xl border border-white/10"
    style="background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(12px);"
  >
    <!-- Logo -->
    <a
      href="/"
      class="font-bold text-xl tracking-tight flex items-center gap-2"
    >
      <img src="/faviconVhaj.svg" alt="favicon" class="w-6 h-6" />
      Andrés <span class="text-accent">Méndez</span>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden md:block">
      <ul class="flex gap-2">
        {
          navLinks.map(({ href, label }) => {
            const isActive =
              currentPath === href ||
              (href !== "/" && currentPath.startsWith(href));
            return (
              <li>
                <a
                  href={href}
                  class={`px-4 py-2 rounded-xl text-sm font-medium transition-all duration-200 ${
                    isActive
                      ? "text-accent bg-accent/10 border border-accent/20"
                      : "text-muted hover:text-white hover:bg-white/5"
                  }`}
                >
                  {label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <!-- GitHub desktop -->
    <a
      href="https://github.com/andfelipeme"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub de Andrés Méndez"
      class="hidden md:flex items-center gap-2 text-sm text-muted hover:text-white transition-colors duration-200"
    >
      <FaGithub className="text-xl" />
    </a>

    <!-- Menú móvil -->
    <MobileMenu client:load />
  </div>
</header>
